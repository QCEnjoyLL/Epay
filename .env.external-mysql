APP_PORT=8080
EPAY_IMAGE=orangeqiu/epay:latest

# If MySQL is installed on the same Linux server, keep host.docker.internal.
# If MySQL is on another server, set DB_HOST to that server IP or hostname.
DB_HOST=host.docker.internal
DB_PORT=3306

MYSQL_DATABASE=epay
MYSQL_USER=epay
MYSQL_PASSWORD=change_this_epay_password
EPAY_DB_PREFIX=pay

# Keep 1 for first install. Set to 0 only when the schema already exists.
EPAY_AUTO_INSTALL=1
