# Common settings for docker-compose.yml and docker-compose.hub.yml
APP_PORT=8080
MYSQL_ROOT_PASSWORD=change_this_root_password
MYSQL_DATABASE=epay
MYSQL_USER=epay
MYSQL_PASSWORD=change_this_epay_password
EPAY_DB_PREFIX=pay

# Only used by docker-compose.hub.yml after GitHub Actions has published the image.
# Example: your-dockerhub-name/epay:latest
DOCKERHUB_IMAGE=your-dockerhub-name/epay:latest
